@* =========================================================
   Views/Admin/AddMenuItem.cshtml
   ADMİN - YENİ ÜRÜN EKLEME FORMU
   
   Modeli: MenuItemViewModel
   Yeni menü ürünü için doldurulacak form.
   ========================================================= *@

@model LiveLifeCoffee.Models.MenuItemViewModel

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
    @* Controller'dan gelen mevcut kategoriler listesi *@
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<div style="max-width: 700px; margin: 0 auto; padding: 30px 20px;">

    @* Başlık ve navigasyon *@
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 24px; flex-wrap:wrap; gap:12px;">
        <h1 style="color: var(--color-primary-dark);">&#x2795; Yeni Ürün Ekle</h1>
        <a href="@Url.Action("Menu", "Admin")" class="btn btn-outline btn-sm">
            &larr; Menüye Dön
        </a>
    </div>

    <div class="card">
        <div class="card-body">

            @* YENİ ÜRÜN FORMU *@
            <form asp-action="AddMenuItem" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                @* Ürün Adı *@
                <div class="form-group">
                    <label asp-for="Name"></label>
                    <input asp-for="Name" type="text" placeholder="Ürün adı (örn: Filtre Kahve)" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>

                @* Açıklama *@
                <div class="form-group">
                    <label asp-for="Description"></label>
                    <textarea asp-for="Description" placeholder="Ürünün kısa açıklaması..." style="min-height: 90px;"></textarea>
                    <span asp-validation-for="Description" class="field-validation-error"></span>
                </div>

                @* Fiyat *@
                <div class="form-group">
                    <label asp-for="Price"></label>
                    <input asp-for="Price" type="number" step="0.01" min="0.01" placeholder="0,00" />
                    <span asp-validation-for="Price" class="field-validation-error"></span>
                </div>

                @* Kategori: mevcut kategorileri gösteren dropdown + yeni kategori girişi *@
                <div class="form-group">
                    <label asp-for="Category"></label>
                    @* Mevcut kategorilerden seçim yapılabilir VEYA yeni yazılabilir *@
                    <input asp-for="Category" type="text"
                           list="category-list"
                           placeholder="Kategori seçin veya yeni yazın" />
                    @* datalist: dropdown öneri listesi (HTML5) *@
                    <datalist id="category-list">
                        @foreach (var cat in categories)
                        {
                            <option value="@cat"></option>
                        }
                    </datalist>
                    <small style="color: var(--color-text-muted); font-size: 0.8rem;">
                        Mevcut kategorilerden seçin ya da yeni kategori adı yazın.
                    </small>
                    <span asp-validation-for="Category" class="field-validation-error"></span>
                </div>

                @* Stok durumu (checkbox) *@
                <div class="form-group" style="display:flex; align-items:center; gap:10px;">
                    <input asp-for="IsAvailable" type="checkbox" style="width:auto; accent-color: var(--color-primary);" />
                    <label asp-for="IsAvailable" style="margin:0;">Stokta Mevcut</label>
                </div>

                @* Kaydet butonu *@
                <div style="display:flex; gap:12px; margin-top: 24px;">
                    <button type="submit" class="btn btn-primary">
                        &#x2713; Ürünü Ekle
                    </button>
                    <a href="@Url.Action("Menu", "Admin")" class="btn btn-outline">İptal</a>
                </div>

            </form>

        </div>
    </div>

</div>
